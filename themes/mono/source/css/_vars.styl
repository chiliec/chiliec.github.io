:root
  --bg #f4f1ea
  --fg #1a1a1a
  --accent #1e5f8e
  --muted #888888
  --rule #d4cfbe
  --code-bg #e8e3d3

  --font-mono 'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace
  --font-body Georgia, 'Times New Roman', serif

  --content-width 680px
  --space-xs 0.25rem
  --space-sm 0.5rem
  --space-md 1rem
  --space-lg 1.5rem
  --space-xl 2.5rem

@media (prefers-color-scheme: dark)
  :root
    --bg #15161a
    --fg #d6d6d0
    --accent #6fb8e8
    --muted #6e6e76
    --rule #2a2b30
    --code-bg #1f2026

// Manual override — wins over the media query
:root[data-theme="light"]
  --bg #f4f1ea
  --fg #1a1a1a
  --accent #1e5f8e
  --muted #888888
  --rule #d4cfbe
  --code-bg #e8e3d3

:root[data-theme="dark"]
  --bg #15161a
  --fg #d6d6d0
  --accent #6fb8e8
  --muted #6e6e76
  --rule #2a2b30
  --code-bg #1f2026
