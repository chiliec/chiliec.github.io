.site-container
  max-width var(--content-width)
  margin 0 auto
  padding var(--space-xl) var(--space-md)

.site-header
  display flex
  justify-content space-between
  align-items baseline
  padding-bottom var(--space-md)
  margin-bottom var(--space-xl)
  border-bottom 1px dashed var(--rule)
  font-family var(--font-mono)
  font-size 13px

.site-name
  font-weight 700
  text-decoration none
  color var(--fg)

.site-name::before
  content '> '
  color var(--accent)

.site-nav a
  margin-left var(--space-md)
  text-decoration none
  color var(--muted)

.site-nav a:hover
  color var(--accent)

.theme-toggle
  background transparent
  border none
  color var(--muted)
  font-family var(--font-mono)
  font-size 14px
  margin-left var(--space-md)
  padding 0
  cursor pointer
  line-height 1

.theme-toggle:hover
  color var(--accent)

.site-footer
  display flex
  justify-content space-between
  margin-top var(--space-xl)
  padding-top var(--space-md)
  border-top 1px dashed var(--rule)
  font-family var(--font-mono)
  font-size 11px
  color var(--muted)

.site-footer a
  color var(--muted)
  text-decoration none
  margin-left var(--space-md)

.site-footer a:hover
  color var(--accent)

.post-list
  list-style none
  padding 0
  margin 0

.post-list-item
  display grid
  grid-template-columns 130px 1fr
  gap var(--space-md)
  align-items baseline
  padding var(--space-sm) 0
  font-family var(--font-mono)
  font-size 13px

.post-list-title
  text-decoration none
  color var(--fg)
  font-weight 600

.post-list-title:hover
  color var(--accent)

.post-meta
  font-family var(--font-mono)
  font-size 11px
  color var(--muted)
  letter-spacing 0.02em

.post-tags
  margin-left var(--space-sm)

.post-tags a
  color var(--muted)
  text-decoration none
  margin-right var(--space-xs)

.post-tags a:hover
  color var(--accent)

@media (max-width: 600px)
  .post-list-item
    grid-template-columns 1fr
    gap var(--space-xs)
