<header class="post-header">
  <h1 class="post-title">archive</h1>
</header>
<ul class="post-list">
  <% page.posts.each(function(post) { %>
    <li class="post-list-item">
      <%- partial('_partial/post-meta', { post: post }) %>
      <a class="post-list-title" href="<%- url_for(post.path) %>"><%= post.title %></a>
    </li>
  <% }) %>
</ul>
