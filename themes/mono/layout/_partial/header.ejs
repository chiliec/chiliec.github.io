<header class="site-header">
  <a class="site-name" href="<%- url_for('/') %>"><%= theme.signature %></a>
  <nav class="site-nav">
    <% for (var label in theme.menu) { %>
      <a href="<%- url_for(theme.menu[label]) %>"><%= label %></a>
    <% } %>
    <button type="button" class="theme-toggle" aria-label="toggle theme" aria-pressed="false">◐</button>
  </nav>
</header>
